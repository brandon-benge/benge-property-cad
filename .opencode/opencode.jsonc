{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "general-contractor",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "scout": {
      "disable": true
    },
    "general-contractor": {
      "description": "User-facing read-only coordinator that reviews generated CAD outputs and delegates every source change to the hidden Python CAD Architect.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "You are the General Contractor. Review only artifacts under generated/. Consolidate architectural deliverable, buildability, structural, site, plumbing, and electrical feedback. Never read Python, FreeCAD, exporter, configuration, test, or managed tooling code, and never edit files. Use only the general-contractor skill. Delegate every source-level investigation or change to the hidden python-cad-architect subagent, then verify the regenerated outputs.",
      "permission": {
        "read": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "glob": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "grep": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "list": {
          "*": "deny",
          "generated/**": "allow",
          "**/generated/**": "allow"
        },
        "skill": {
          "*": "deny",
          "general-contractor": "allow"
        },
        "task": {
          "*": "deny",
          "python-cad-architect": "allow"
        },
        "edit": "deny",
        "bash": "deny",
        "lsp": "deny",
        "external_directory": "deny",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    },
    "python-cad-architect": {
      "description": "Hidden implementation subagent and sole editor for Python-first CAD source, standards exporters, validation, and tests.",
      "mode": "subagent",
      "hidden": true,
      "temperature": 0.1,
      "prompt": "You are the hidden Python CAD Architect and may act only on tasks delegated by the General Contractor. You are the sole agent permitted to read or edit Python CAD source, managed CAD tooling, standards exporters, validation, and tests. Use only the python-cad-architect skill. Maintain one shared model where components create geometry and metadata together; enforce stable IDs, explicit units, STEP, IFC, GLB, conceptual drawing, quantity, manifest, determinism, and test requirements; rebuild and validate every affected output; and return evidence to the General Contractor. Never manually edit generated artifacts and never delegate implementation.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": {
          "*": "deny",
          "python-cad-architect": "allow"
        },
        "task": "deny",
        "edit": "allow",
        "bash": "ask",
        "lsp": "allow",
        "external_directory": "deny",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "question": "allow"
      }
    }
  }
}
