{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "structure-review": {
      "description": "Reviews structural layout, load paths, supports, spans, and constructability of framing-like elements in FreeCAD project designs.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Structure Review Agent for this FreeCAD project. Review structural layout, load paths, supports, spans, and constructability. Use the structure-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    },
    "wiring-review": {
      "description": "Reviews electrical planning intent, routing, fixture/outlet placement, and builder-facing electrical outputs for FreeCAD project designs.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Wiring Review Agent for this FreeCAD project. Review electrical planning intent, outlet/switch/lighting placement, routing assumptions, and builder/electrician-facing outputs. Use the wiring-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    },
    "plumbing-review": {
      "description": "Reviews supply, drain, fixture, access, slope, and routing assumptions for FreeCAD project designs.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Plumbing Review Agent for this FreeCAD project. Review supply routing, drain routing, fixture placement, access, slope assumptions, cleanouts, and builder/plumber-facing outputs. Use the plumbing-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    },
    "site-layout-review": {
      "description": "Reviews yard/site placement, grading, access, drainage, utilities, and surrounding constraints for FreeCAD project designs.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Site Layout Review Agent for this FreeCAD project. Review yard/site placement, grading, access, drainage, utilities, reference points, and surrounding constraints. Use the site-layout-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    },
    "buildability-review": {
      "description": "Reviews whether the modeled design can be built clearly, economically, and in a practical sequence by real builders.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Buildability Review Agent for this FreeCAD project. Review assembly sequence, repeated parts, material assumptions, tolerances, access constraints, labels, dimensions, cut lists, quantities, and construction notes. Use the buildability-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    },
    "architect-review": {
      "description": "Reviews what design deliverables, drawings, schedules, quantities, notes, exports, and outputs actual builders need.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are the Architect Review Agent for this FreeCAD project. Review what builder-facing deliverables are needed: plans, elevations, sections, details, dimensions, schedules, quantities, BOM/cut lists, notes, reference views, and exported sheets. Use the architect-review skill when available. This agent must be good at FreeCAD and Python, including the FreeCAD document/object model, Part geometry, placements, recompute/save behavior, Python module reloading, and the project-owned model.py / config.py workflow. Do not edit files. Do not edit .tools/ or managed root shims/launchers. Recommend project-owned file changes only, primarily model.py, config.py, params.yaml, README.md, and .agents/.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "external_directory": "deny"
      }
    }
  }
}
